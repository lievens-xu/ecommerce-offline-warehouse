__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.venv/
venv/
env/

# =========================
# Environment
# =========================
.env
.env.local

# =========================
# Data files
# Raw and intermediate warehouse data should not be committed
# =========================
data/raw/*
data/ods/*
data/dwd/*
data/dws/*
data/ads/*

# Keep folder structure
!data/raw/.gitkeep
!data/ods/.gitkeep
!data/dwd/.gitkeep
!data/dws/.gitkeep
!data/ads/.gitkeep

# =========================
# Personal notes (do not upload) / 个人学习笔记（不上传）
# =========================
LEARNING_NOTES.md

# =========================
# Logs
# =========================
*.log
docs/pipeline_latest_run.log

# =========================
# Jupyter
# =========================
.ipynb_checkpoints/

# =========================
# IDE
# =========================
.vscode/
.idea/

# =========================
# System
# =========================
.DS_Store
Thumbs.db

# =========================
# Docker / Docker 相关
# =========================
# Docker volumes are managed by Docker, not Git
# Docker 卷由 Docker 管理，不应提交到 Git
postgres_data/

# =========================
# dbt
# =========================
# Local dbt profile with database credentials / 包含数据库凭据的本地 dbt 配置
dbt/ecommerce_warehouse/profiles.yml
# dbt target directory / dbt 目标目录
dbt/ecommerce_warehouse/target/
# dbt logs / dbt 日志
dbt/ecommerce_warehouse/logs/

# =========================
# Airflow / Airflow 相关
# =========================
# Airflow local runtime artifacts / Airflow 本地运行时产物
airflow/.env
airflow/config/profiles.yml
airflow/logs/*
airflow/airflow.db
airflow/airflow.cfg
airflow/airflow.cfg
airflow/webserver_config.py
# Keep airflow/logs directory structure
!airflow/logs/.gitkeep

# =========================
# Superset / Superset 相关
# =========================
# Superset local environment file / Superset 本地环境文件
superset/.env
# Superset runtime artifacts / Superset 运行时产物
superset/superset.db*