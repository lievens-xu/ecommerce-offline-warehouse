# Airflow dbt Profile for E-Commerce Warehouse
# Airflow dbt 电商数仓配置
#
# This profile is used by Airflow containers to connect to PostgreSQL
# via host.docker.internal.
# 此配置供 Airflow 容器通过 host.docker.internal 连接 PostgreSQL。
#
# Copy this file to profiles.yml and adjust values as needed.
# 将此文件复制为 profiles.yml 并根据需要调整。

ecommerce_warehouse:
  target: airflow
  outputs:
    airflow:
      type: postgres
      host: "{{ env_var('POSTGRES_HOST', 'host.docker.internal') }}"
      port: "{{ env_var('POSTGRES_PORT', '5433') | int }}"
      database: "{{ env_var('POSTGRES_DB', 'ecommerce_warehouse') }}"
      user: "{{ env_var('POSTGRES_USER', 'warehouse_user') }}"
      password: "{{ env_var('POSTGRES_PASSWORD', 'warehouse_pass') }}"
      schema: dbt_airflow
      threads: 2
      keepalives_idle: 0
      connect_timeout: 10
      sslmode: prefer